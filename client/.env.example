# Google Sign-In button for the React client.
# Use the same Web OAuth Client ID configured as GOOGLE_CLIENT_ID in server/.env.
REACT_APP_GOOGLE_CLIENT_ID=your_google_oauth_web_client_id.apps.googleusercontent.com

# Optional production API override. Local development uses the proxy in package.json.
# REACT_APP_API_URL=https://your-api.example.com
