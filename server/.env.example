# AI API Key (Groq or DeepSeek)
GROQ_API_KEY=PASTE_GROQ_API_KEY_HERE

# Server Configuration
PORT=3001
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:3000
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d
GOOGLE_CLIENT_ID=your_google_oauth_web_client_id.apps.googleusercontent.com
# Optional: set true only if you want to keep email/password signup after Google is configured.
ALLOW_PASSWORD_REGISTER=false
ADMIN_EMAIL=admin@binaapal.com
ADMIN_PASSWORD=replace_with_a_strong_admin_password
SEED_WORKER_PASSWORD=password123

# Database Configuration
DB_USERNAME=root
DB_PASSWORD=your_database_password
DB_NAME=BinaaPall2
DB_HOST=localhost
DB_PORT=3306
DB_DIALECT=mysql
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true
# Use this instead of DB_* when your host provides a single connection URL.
DATABASE_URL=
# Railway MySQL may provide MYSQL_URL or MYSQLHOST/MYSQLUSER/MYSQLPASSWORD/MYSQLDATABASE/MYSQLPORT.
MYSQL_URL=

# n8n Integrations
N8N_WORKER_REQUEST_WEBHOOK_URL=PASTE_N8N_PRODUCTION_URL_HERE
