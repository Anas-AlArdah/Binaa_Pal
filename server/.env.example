# Server Configuration
PORT=3001
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:3000
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d
GOOGLE_CLIENT_ID=your_google_oauth_web_client_id.apps.googleusercontent.com
ADMIN_EMAIL=admin@binaapal.com
ADMIN_PASSWORD=replace_with_a_strong_admin_password
# Optional bcrypt hash of ADMIN_PASSWORD. If set, ADMIN_PASSWORD is ignored.
ADMIN_PASSWORD_HASH=
SEED_WORKER_PASSWORD=password123

# Supabase Database (PostgreSQL)
# Dashboard -> Connect -> Session pooler (port 5432).
SUPABASE_DATABASE_URL=postgresql://postgres.PROJECT_REF:DB_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres
SEQUELIZE_LOGGING=false

# Gmail SMTP (required for email verification on registration)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-16-character-google-app-password
EMAIL_FROM=Binaa Pal <your-email@gmail.com>

# n8n (optional)
N8N_WORKER_REQUEST_WEBHOOK_URL=PASTE_N8N_PRODUCTION_URL_HERE
N8N_WEBHOOK_TIMEOUT_MS=8000

# AI (optional)
GROQ_API_KEY=PASTE_GROQ_API_KEY_HERE
